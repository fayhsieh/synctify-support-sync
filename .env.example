# 複製本檔為 .env 並填入實際值。.env 不會進版控。
# 正式運作時這些值應存在 n8n credential 中，此檔僅供本機測試腳本使用。

# ── WordPress ────────────────────────────────────
WP_BASE_URL=https://support.synctify.io
WP_USERNAME=
# 使用者 → 個人資料 → Application Passwords 產生（格式：xxxx xxxx xxxx xxxx xxxx xxxx）
WP_APP_PASSWORD=

# ── Notion ───────────────────────────────────────
NOTION_API_KEY=
NOTION_CONTENT_HUB_DB_ID=3272f2ed-e27d-80f9-8e2d-000be0502aa8
NOTION_GLOSSARY_DB_ID=28d2f2ed-e27d-805b-90f3-000b73c8a2af

# ── OpenAI（翻譯）────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=

# ── n8n webhook 驗證 ─────────────────────────────
# Notion 按鈕呼叫 webhook 時帶的 header token，隨機字串即可
N8N_WEBHOOK_TOKEN=

# ── TranslatePress ───────────────────────────────
TP_TARGET_LANGUAGE=zh_CN
